    def get_save_path(self):
        """Get the save file path in AppData (hidden from players)."""
        appdata = os.environ.get('APPDATA', os.path.expanduser('~/.local/share'))
        save_dir = os.path.join(appdata, 'TheBigAdventure')
        os.makedirs(save_dir, exist_ok=True)
        return os.path.join(save_dir, 'Player_save.json')
    
    def save_game(self):
        """Save game to file."""
        if self.game is None or self.game.player is None:
            messagebox.showwarning("No Game", "No active game to save! Start a new game or load one first.")
            return
        
        save_data = {
            "player": {
                "name": self.game.player.name,
                "race": self.game.player.race,
                "power": self.game.player.power,
                "health": self.game.player.health,
                "maxHP": self.game.player.maxHP,
                "defense": self.game.player.defense,
                "luck": self.game.player.luck,
                "speed": self.game.player.speed,
                "level": self.game.player.level,
                "xp": self.game.player.xp,
                "max_xp": self.game.player.max_xp,
                "gold": self.game.player.gold,
                "mp": self.game.player.mp,
                "maxMP": self.game.player.maxMP,
                "inventory": self.game.player.inventory,
                "equipped": self.game.player.equipped,
            },
            "state": {
                "day": self.game.state.day,
                "hour": self.game.state.hour,
                "visited_locations": list(self.game.state.visited_locations),
                "npc_completed": self.game.state.npc_completed,
                "reputation": self.game.state.reputation,
                "guilds": self.game.state.guilds,
            }
        }
        
        try:
            save_path = self.get_save_path()
            with open(save_path, "w") as f:
                json.dump(save_data, f, indent=2)
            messagebox.showinfo("Save Game", "Game saved successfully!")
        except Exception as e:
            messagebox.showerror("Error", f"Failed to save: {e}")
    
    def load_game(self):
        """Load game from file."""
        save_path = self.get_save_path()
        if not os.path.exists(save_path):
            messagebox.showwarning("No Save", "No saved game found!")
            return
        
        try:
            with open(save_path, "r") as f:
                save_data = json.load(f)
            
            self.game = Menu.Game(list(self.NPCS.keys()), self)
            
            p = save_data["player"]
            self.game.player = Menu.Player(p["name"], p["race"])
            self.game.player.power = p["power"]
            self.game.player.health = p["health"]
            self.game.player.maxHP = p["maxHP"]
            self.game.player.defense = p["defense"]
            self.game.player.luck = p["luck"]
            self.game.player.speed = p["speed"]
            self.game.player.level = p["level"]
            self.game.player.xp = p["xp"]
            self.game.player.max_xp = p["max_xp"]
            self.game.player.gold = p["gold"]
            self.game.player.mp = p.get("mp", 50)
            self.game.player.maxMP = p.get("maxMP", 50)
            self.game.player.inventory = p.get("inventory", [])
            self.game.player.equipped = p.get("equipped", {"weapon": None, "armor": None, "accessory1": None, "accessory2": None})
            
            s = save_data["state"]
            self.game.state.day = s["day"]
            self.game.state.hour = s["hour"]
            self.game.state.visited_locations = set(s.get("visited_locations", []))
            self.game.state.npc_completed = s.get("npc_completed", {})
            self.game.state.reputation = s.get("reputation", {})
            self.game.state.guilds = s.get("guilds", {})
            
            for widget in self.button_frame.winfo_children():
                widget.destroy()
            
            self.gui_print(f"✅ Game loaded! Welcome back, {self.game.player.name}!")
            self.game_loop()
            
        except Exception as e:
            messagebox.showerror("Error", f"Failed to load: {e}")
    
    

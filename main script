    def handle_npc_select(self, npc):
        if npc and npc != "back":
            self.npc_menu(npc)
        elif npc == "back":
            self.game_loop()
    
    def npc_menu(self, key):
        name, role, greet, tasks = self.NPCS[key]
        self.gui_print(f"\n👤 {name} - {role}")
        self.gui_print(f"'{greet}'")
        
        self.show_inline_buttons(f"NPC: {name}", [
            ("📋 Get Task", "1"),
            ("✅ Completed", "2"),
            ("💬 Talk", "3"),
            ("⬅️ Exit", "4")
        ], lambda c: self.handle_npc_choice(key, c, tasks))
    
    def handle_npc_choice(self, key, c, tasks):
        """Handle NPC menu selection."""
        if c == "back":
            # Go back to NPC selection
            self.handle_npc_select(key)
        elif c == "4":
            # Exit - go back to main menu
            self.game_loop()
        elif c == "1":
            # Get Task - show available tasks
            available = [t for t in tasks if t[0] not in self.game.state.npc_completed[key]]
            if not available:
                self.gui_print("All tasks done!")
                self.game_loop()
                return
            self.gui_print("Available tasks:")
            for i, t in enumerate(available):
                self.gui_print(f"{i+1}. {t[0]} - {t[1]} (XP:{t[2]} Gold:{t[3]})")
            
            task_choices = []
            for i, t in enumerate(available):
                task_choices.append((f"{t[0]}", i))
            task_choices.append(("⬅️ Back", "back"))
            
            self.root.update()
            self.show_inline_buttons("Select Task", task_choices,
                                   lambda x: self.handle_task_selection(key, x, available))
        elif c == "2":
            self.gui_print(f"Completed: {self.game.state.npc_completed[key]}")
            self.root.after(100, lambda: self.game_loop())
        elif c == "3":
            name = self.NPCS[key][0]
            self.gui_print(f"{name}: 'Thanks for your help, adventurer!'")
            self.root.after(100, lambda: self.game_loop())
    
    def handle_task_selection(self, key, choice, available_tasks):
        if choice == "back" or choice is None:
            self.npc_menu(key)
        elif isinstance(choice, int) and 0 <= choice < len(available_tasks):
            task = available_tasks[choice]
            self.gui_print(f"📋 Accepted: {task[0]}")
            self.gui_print(f"Goal: {task[1]}")
            self.game.state.npc_completed[key].append(task[0])
            self.root.after(100, lambda: self.start_npc_task(key, task))
    
    def start_npc_task(self, key, task):
        task_name = task[0]
        
        if "Train" in task_name or "Practice" in task_name:
            self.game.gain_xp(task[2], self.gui_print)
            self.game.player.gold += task[3]
            self.gui_print(f"✅ Done! +{task[2]}XP +{task[3]}g")
        elif "Defend" in task_name or "Help defend" in task_name:
            self.game.create_enemy()
            self._start_fight()
        elif "Craft" in task_name or "Help craft" in task_name:
            self.game.gain_xp(task[2], self.gui_print)
            self.game.player.gold += task[3]
            self.gui_print(f"✅ Done! +{task[2]}XP +{task[3]}g")
        elif "Gather" in task_name or "Find" in task_name:
            self.game.gain_xp(task[2], self.gui_print)
            self.game.player.gold += task[3]
            self.gui_print(f"✅ Done! +{task[2]}XP +{task[3]}g")
        else:
            self.game.gain_xp(task[2], self.gui_print)
            self.game.player.gold += task[3]
            self.gui_print(f"✅ Done! +{task[2]}XP +{task[3]}g")
        
        self.root.after(100, lambda: self.game_loop())
    
    def handle_explore(self, loc):
        if loc and loc != "back":
            self.explore(loc)
        elif loc == "back":
            self.game_loop()
    
    def explore(self, loc_key):
        name, desc, enemies, danger = self.LOCATIONS[loc_key]
        self.gui_print(f"\n📍 {name}")
        self.gui_print(f"Description: {desc}")
        self.gui_print(f"Danger Level: {'★'*danger}")
        
        self.game.state.visited_locations.add(loc_key)
        self.game.state.advance_time(2)
        
        if enemies and random.random() < 0.5:  # 50% chance
            self.game.create_enemy()
            self._start_fight()
        else:
            self.game.gain_xp(random.randint(10, 25), self.gui_print)
            self.gui_print("✅ Explored safely! Gained XP.")
            self.root.update()
            self.game_loop()
    
    def _start_fight(self):
        """Start a combat encounter and ensure we return to game loop after."""
        # Create a wrapper that handles combat results
        def combat_callback(c):
            result = self.game._handle_combat(c, self.gui_print, self.show_inline_buttons, self.root.update, self.ITEMS)
            
            # If combat ended, return to game loop
            if result in ["victory", "escaped", "died"]:
                self.root.after(100, lambda: self.game_loop())
            else:
                # Continue combat - show combat menu again
                self.root.after(100, lambda: self._continue_combat())
        
        # Start the fight
        self.game.fight(self.gui_print, self.show_inline_buttons, self.root.update, self.ITEMS, combat_callback)

    def _continue_combat(self):
        """Continue combat after a round."""
        # Show the combat menu again
        self.show_inline_buttons("Combat", [
            ("⚔️ Attack", "1"),
            ("🛡️ Defend", "2"),
            ("💫 Special", "3"),
            ("🏃 Run", "4")
        ], lambda c: self._handle_combat_input(c))

    def _handle_combat_input(self, c):
        """Handle combat input and continue."""
        result = self.game._handle_combat(c, self.gui_print, self.show_inline_buttons, self.root.update, self.ITEMS)
        
        if result in ["victory", "escaped", "died"]:
            self.root.after(100, lambda: self.game_loop())
        else:
            self.root.after(100, lambda: self._continue_combat())
    

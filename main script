    class Player:
        """Player character with stats and inventory."""
        def __init__(self, name, race):
            self.name = name
            self.race = race
            
            stats = {
                "Human": (10, 100, 5, 1, 5),
                "Ork": (20, 200, 10, 1, 2.5),
                "Elf": (5, 50, 2.5, 1, 10),
                "Dwarf": (15, 150, 8, 2, 3),
            }
            p, hp, d, l, s = stats.get(race, (10, 100, 5, 1, 5))
            
            self.power = p
            self.health = hp
            self.maxHP = hp
            self.defense = d
            self.luck = l
            self.speed = s
            self.level = 1
            self.xp = 0
            self.max_xp = 100
            self.gold = 100
            self.mp = 50
            self.maxMP = 50
            
            # Inventory: list of item keys
            self.inventory = []
            # Equipped items: {"weapon": item_key, "armor": item_key, etc.}
            self.equipped = {"weapon": None, "armor": None, "accessory1": None, "accessory2": None}
    
    
    class GameState:
        """Game world state."""
        def __init__(self, npc_keys):
            self.day = 1
            self.hour = 8
            self.visited_locations = set()
            self.npc_completed = {k: [] for k in npc_keys}
            self.reputation = {}
            self.guilds = {}
            self.equipment = {}
        
        def get_time_period(self):
            if 6 <= self.hour < 12: return "Morning"
            elif 12 <= self.hour < 18: return "Afternoon"
            elif 18 <= self.hour < 22: return "Evening"
            else: return "Night"
        
        def advance_time(self, hours):
            self.hour += hours
            while self.hour >= 24:
                self.hour -= 24
                self.day += 1
    
    
    class Game:
        """Main game controller."""
        def __init__(self, npc_keys, parent=None):
            self.player = None
            self.state = Menu.GameState(npc_keys)
            self.enemy = None
            self.parent = parent  # Reference to Menu class for accessing data
        
        def create_player(self, name, race):
            self.player = Menu.Player(name, race)
        
        def get_player_power(self):
            """Calculate total power including equipment."""
            power = self.player.power
            for slot, item_key in self.player.equipped.items():
                if item_key:
                    # Get power bonus from item
                    power += 2  # Base bonus
            return power
        
        def get_player_defense(self):
            """Calculate total defense including equipment."""
            defense = self.player.defense
            for slot, item_key in self.player.equipped.items():
                if item_key:
                    defense += 2  # Base bonus
            return defense
        
        def gain_xp(self, amount, gui_print_func):
            self.player.xp += amount
            while self.player.xp >= self.player.max_xp:
                self.player.xp -= self.player.max_xp
                self.player.level += 1
                self.player.max_xp = int(self.player.max_xp * 1.5)
                self.player.power += 5
                self.player.maxHP += 20
                self.player.maxMP += 10
                gui_print_func(f"🎉 Level up! Now level {self.player.level}!")
        
        def create_enemy(self):
            """Create a random enemy with random stats."""
            enemies = list(self.parent.ENEMIES.keys())
            e = random.choice(enemies)
            data = self.parent.ENEMIES[e]
            self.enemy = type('Enemy', (), {
                "key": e,
                "race": data[0],
                "power": data[1],
                "health": data[2],
                "defense": data[3],
                "xp_reward": data[4],
                "gold_reward": data[5]
            })()
        
        def fight(self, gui_print_func, show_buttons_func, root_update, items_db, callback=None):
            """Start a combat encounter."""
            gui_print_func(f"⚔️ FIGHT! Enemy: {self.enemy.race}")
            gui_print_func(f"Your HP: {self.player.health}/{self.player.maxHP} | MP: {self.player.mp}/{self.player.maxMP}")
            gui_print_func(f"Enemy HP: {self.enemy.health}")
            root_update()
            
            # Show combat buttons
            show_buttons_func("Combat", [
                ("⚔️ Attack", "1"),
                ("🛡️ Defend", "2"),
                ("💫 Special", "3"),
                ("🏃 Run", "4")
            ], callback if callback else lambda c: None)
        
        def _handle_combat(self, c, gui_print_func, show_buttons_func, root_update, items_db):
            if c == "1":  # Attack
                player_power = self.get_player_power()
                dmg = max(1, player_power - self.enemy.defense + random.randint(-3, 3))
                self.enemy.health -= dmg
                gui_print_func(f"You deal {dmg} damage to {self.enemy.race}!")
            elif c == "2":  # Defend
                dmg = max(0, self.enemy.power - self.get_player_defense())
                self.player.health -= dmg
                gui_print_func(f"Defended! Took {dmg} damage.")
            elif c == "3":  # Special (costs MP)
                if self.player.mp >= 10:
                    self.player.mp -= 10
                    player_power = self.get_player_power()
                    dmg = max(1, player_power * 2 - self.enemy.defense)
                    self.enemy.health -= dmg
                    gui_print_func(f"🔥 Special attack! {dmg} damage!")
                else:
                    gui_print_func("Not enough MP! Need 10 MP for special.")
                    return "continue"
            elif c == "4":  # Run
                if random.random() < 0.5:
                    gui_print_func("Escaped!")
                    return "escaped"
                else:
                    gui_print_func("Failed to escape!")
            
            if self.enemy.health <= 0:
                gui_print_func(f"🎉 Victory! +{self.enemy.xp_reward}XP +{self.enemy.gold_reward}gold")
                self.gain_xp(self.enemy.xp_reward, gui_print_func)
                self.player.gold += self.enemy.gold_reward
                return "victory"
            
            # Enemy attacks
            dmg = max(0, self.enemy.power - self.get_player_defense())
            self.player.health -= dmg
            gui_print_func(f"{self.enemy.race} deals {dmg} damage!")
            
            if self.player.health <= 0:
                gui_print_func("💀 You died! Game over.")
                self.player.health = self.player.maxHP
                self.player.mp = self.player.maxMP
                return "died"
            
            return "continue"



    def shop_menu(self):
        """Show shop menu."""
        self.gui_print("\n🏪 SHOP")
        self.gui_print(f"Your gold: {self.game.player.gold}g")
        
        self.gui_print("\nItems for sale:")
        for key, item in self.ITEMS.items():
            self.gui_print(f"  {item[0]} - {item[5]} | Price: {item[4]}g")
        
        self.show_inline_buttons("Shop", [
            ("💰 Buy Items", "1"),
            ("💵 Sell Items", "2"),
            ("⬅️ Back", "back")
        ], lambda c: self.handle_shop_choice(c))
    
    def handle_shop_choice(self, c):
        """Handle shop menu."""
        if c == "back":
            self.game_loop()
        elif c == "1":  # Buy
            self._show_buy_menu()
        elif c == "2":  # Sell
            self._show_sell_menu()
    
    def _show_buy_menu(self):
        """Show items to buy."""
        self.gui_print("\n💰 BUY ITEMS")
        self.gui_print(f"Your gold: {self.game.player.gold}g")
        
        choices = []
        for key, item in self.ITEMS.items():
            choices.append((f"{item[0]} ({item[4]}g)", key))
        choices.append(("⬅️ Back", "back"))
        
        self.show_inline_buttons("Buy", choices, lambda item: self._buy_item(item))
    
    def _buy_item(self, item_key):
        """Buy an item."""
        if item_key == "back" or item_key is None:
            self.shop_menu()
            return
        
        if item_key not in self.ITEMS:
            return
        
        item = self.ITEMS[item_key]
        price = item[4]
        
        if self.game.player.gold >= price:
            self.game.player.gold -= price
            self.game.player.inventory.append(item_key)
            self.gui_print(f"✅ Bought {item[0]} for {price}g!")
        else:
            self.gui_print(f"❌ Not enough gold! Need {price}g, have {self.game.player.gold}g.")
        
        self.root.after(100, lambda: self._show_buy_menu())
    
    def _show_sell_menu(self):
        """Show items to sell."""
        player = self.game.player
        
        if not player.inventory:
            self.gui_print("No items to sell!")
            self.root.after(100, lambda: self.shop_menu())
            return
        
        self.gui_print("\n💵 SELL ITEMS")
        self.gui_print(f"Your gold: {player.gold}g")
        
        choices = []
        for item_key in player.inventory:
            if item_key in self.ITEMS:
                item = self.ITEMS[item_key]
                sell_price = item[4] // 2  # Sell for half price
                choices.append((f"{item[0]} ({sell_price}g)", item_key))
        
        choices.append(("⬅️ Back", "back"))
        
        self.show_inline_buttons("Sell", choices, lambda item: self._sell_item(item))
    
    def _sell_item(self, item_key):
        """Sell an item."""
        if item_key == "back" or item_key is None:
            self.shop_menu()
            return
        
        if item_key not in self.ITEMS:
            return
        
        item = self.ITEMS[item_key]
        sell_price = item[4] // 2
        
        self.game.player.gold += sell_price
        self.game.player.inventory.remove(item_key)
        
        self.gui_print(f"✅ Sold {item[0]} for {sell_price}g!")
        self.root.after(100, lambda: self._show_sell_menu())
    
    

    def start_new_game(self):
        """Start new game with race selection."""
        self.game = Menu.Game(list(self.NPCS.keys()), self)
        
        # Race selection
        for widget in self.button_frame.winfo_children():
            widget.destroy()
        
        tk.Label(self.button_frame, text="Choose Your Race", font=("Arial", 24, "bold"),
                 bg="#1a1a2e", fg="#ffd700").pack(pady=20)
        
        races = [
            ("Human (Balanced)", "Human"),
            ("Ork (Strong)", "Ork"),
            ("Elf (Fast)", "Elf"),
            ("Dwarf (Tough)", "Dwarf"),
        ]
        
        for text, race in races:
            tk.Button(self.button_frame, text=text, font=("Arial", 14),
                      bg="#4a4a6a", fg="#ffffff", width=20, height=2,
                      command=lambda r=race: self._create_character(r)).pack(pady=5)
    
    def _create_character(self, race):
        """Create character with selected race."""
        self.game.create_player("Hero", race)
        
        # Give starting items
        self.game.player.inventory = ["sword", "health_potion"]
        self.game.player.equipped["weapon"] = "sword"
        
        for widget in self.button_frame.winfo_children():
            widget.destroy()
        
        self.gui_print(f"Welcome to The Big Adventure!")
        self.gui_print(f"You are a {race} adventurer!")
        self.gui_print("You received: Iron Sword, Health Potion")
        self.game_loop()
    
    
    def game_loop(self):
        """Main game loop."""
        time_period = self.game.state.get_time_period()
        
        # Calculate stats with equipment
        power = self.game.get_player_power()
        defense = self.game.get_player_defense()
        
        self.gui_print(f"\n⏰ Day {self.game.state.day}, {self.game.state.hour}:00 ({time_period})")
        self.gui_print(f"💰{self.game.player.gold}g | ❤️{self.game.player.health}/{self.game.player.maxHP} | 💎{self.game.player.mp}/{self.game.player.maxMP}")
        self.gui_print(f"⚔️ Power: {power} | 🛡️ Defense: {defense} | 📦 Items: {len(self.game.player.inventory)}")
        
        if time_period == "night":
            self.gui_print("🌙 Night time. Some shops may be closed.")
        
        self.show_inline_buttons("Main Menu", [
            ("📜 Quests", "1"),
            ("👤 NPCs", "2"),
            ("🗺️ Explore", "3"),
            ("🏛️ Guild", "4"),
            ("🎒 Inventory", "5"),
            ("🏪 Shop", "6"),
            ("😴 Rest", "7"),
            ("📊 Stats", "8"),
            ("💾 Save", "save"),
            ("❌ Quit", "quit")
        ], lambda c: self.handle_menu_choice(c))
        self.root.update()
    
    
    def handle_menu_choice(self, c):
        """Handle main menu selection."""
        if c == "back":
            # Back button - return to game loop
            self.game_loop()
        elif c == "1":  # Quests
            self.show_inline_buttons("Quests", [
                ("📝 Daily Quest", "1"),
                ("📖 Story Quest", "2"),
                ("🏆 Achievements", "3"),
                ("⬅️ Back", "back")
            ], lambda sub: self.handle_quest_choice(sub))
        elif c == "2":  # NPCs
            self.gui_print("\n👤 NPCs:")
            for k, v in self.NPCS.items():
                self.gui_print(f"  {k.title()}: {v[0]} - {v[1]}")
            npc_choices = [(f"{v[0]}", k) for k, v in self.NPCS.items()]
            npc_choices.append(("⬅️ Back", "back"))
            self.show_inline_buttons("Select NPC", npc_choices, lambda npc: self.handle_npc_select(npc))
        elif c == "3":  # Explore
            self.gui_print("\n🗺️ Locations:")
            for k, v in self.LOCATIONS.items():
                danger = "★" * v[3]
                self.gui_print(f"  {v[0]}: {v[1][:30]}... Danger: {danger}")
            loc_choices = [(f"{v[0]}", k) for k, v in self.LOCATIONS.items()]
            loc_choices.append(("⬅️ Back", "back"))
            self.show_inline_buttons("Select Location", loc_choices, lambda loc: self.handle_explore(loc))
        elif c == "4":  # Guild
            self.guild_menu()
        elif c == "5":  # Inventory
            self.inventory_menu()
        elif c == "6":  # Shop
            self.shop_menu()
        elif c == "7":  # Rest
            heal = random.randint(30, 50)
            mp_restore = random.randint(10, 20)
            self.game.player.health = min(self.game.player.health + heal, self.game.player.maxHP)
            self.game.player.mp = min(self.game.player.mp + mp_restore, self.game.player.maxMP)
            self.game.state.advance_time(6)
            self.gui_print(f"😴 You rested well. Healed {heal} HP and restored {mp_restore} MP.")
            self.root.after(100, lambda: self.game_loop())
        elif c == "8":  # Stats
            power = self.game.get_player_power()
            defense = self.game.get_player_defense()
            messagebox.showinfo("Player Stats",
                f"Name: {self.game.player.name}\nRace: {self.game.player.race}\nLevel: {self.game.player.level}\n\n"
                f"❤️ HP: {self.game.player.health}/{self.game.player.maxHP}\n"
                f"💎 MP: {self.game.player.mp}/{self.game.player.maxMP}\n"
                f"⚔️ Power: {self.game.player.power} (+{power - self.game.player.power} from gear)\n"
                f"🛡️ Defense: {self.game.player.defense} (+{defense - self.game.player.defense} from gear)\n"
                f"🍀 Luck: {self.game.player.luck}\n"
                f"💨 Speed: {self.game.player.speed}\n\n"
                f"📊 XP: {self.game.player.xp}/{self.game.player.max_xp}\n"
                f"💰 Gold: {self.game.player.gold}\n"
                f"📦 Inventory: {len(self.game.player.inventory)} items")
            self.root.after(100, lambda: self.game_loop())
        elif c == "save":
            self.save_game()
            self.root.after(100, lambda: self.game_loop())
        elif c == "quit":
            response = messagebox.askyesno("Quit Game", "Would you like to save before quitting?")
            if response:
                self.save_game()
            self.root.destroy()
    
    

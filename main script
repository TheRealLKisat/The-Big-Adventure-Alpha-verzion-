    def _create_gui_layout(self):
        """Create the two-panel layout."""
        self.main_container = tk.PanedWindow(self.root, orient="horizontal", bg="#1a1a2e", sashwidth=5)
        self.main_container.pack(fill="both", expand=True)
        
        # Left: Text display
        self.text_frame = tk.Frame(self.main_container, bg="#1a1a2e")
        self.main_container.add(self.text_frame, width=360)
        
        self.game_text = scrolledtext.ScrolledText(
            self.text_frame, width=40, height=25,
            font=("Consolas", 11), bg="#1e1e1e", fg="#00ff00", insertbackground="#00ff00"
        )
        self.game_text.pack(fill="both", expand=True, padx=10, pady=10)
        self.game_text.config(state="disabled")
        
        # Right: Buttons
        self.button_frame = tk.Frame(self.main_container, bg="#1a1a2e")
        self.main_container.add(self.button_frame, width=540)
    
    
    def gui_print(self, text=""):
        """Display text in the game area."""
        self.text_buffer.append(str(text))
        self.game_text.config(state="normal")
        self.game_text.delete("1.0", "end")
        self.game_text.insert("end", "\n".join(self.text_buffer) + "\n")
        self.game_text.see("end")
        self.game_text.config(state="disabled")
        self.root.update()
    
    
    def clear_buffer(self):
        """Clear text buffer."""
        self.text_buffer.clear()
    
    
    def show_inline_buttons(self, title, choices, callback):
        """Create menu buttons."""
        for widget in self.button_frame.winfo_children():
            widget.destroy()
        
        tk.Label(self.button_frame, text=title, font=("Arial", 18, "bold"),
                 bg="#1a1a2e", fg="#ffd700").pack(pady=20)
        
        btn_container = tk.Frame(self.button_frame, bg="#1a1a2e")
        btn_container.pack(pady=10)
        
        for i, (btn_text, btn_value) in enumerate(choices):
            btn = tk.Button(btn_container, text=btn_text, font=("Arial", 14),
                            bg="#4a4a6a", fg="#ffffff", width=18, height=2,
                            command=lambda v=btn_value: self._hide_inline_buttons(v, callback))
            row = i // 2
            col = i % 2
            btn.grid(row=row, column=col, padx=10, pady=10)
        
        tk.Button(self.button_frame, text="⬅️ Back", font=("Arial", 12),
                  bg="#6a4a4a", fg="#ffffff",
                  command=lambda: self._hide_inline_buttons("back", callback)).pack(pady=20)
        
        self.root.update()
        self.root.update_idletasks()
        # Ensure window can receive keyboard input
        self.root.focus_force()
    
    
    def _hide_inline_buttons(self, choice, callback):
        """Handle button click."""
        for widget in self.button_frame.winfo_children():
            widget.destroy()
        
        # Call callback with the choice value
        # If choice is "back", pass it as is so handler can decide what to do
        if choice is not None:
            callback(choice)
        self.root.update()
    
    

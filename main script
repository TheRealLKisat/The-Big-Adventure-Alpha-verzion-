    def inventory_menu(self):
        """Show inventory menu."""
        self.gui_print("\n🎒 INVENTORY")
        
        player = self.game.player
        items = []
        
        # Show inventory items
        if player.inventory:
            for item_key in player.inventory:
                if item_key in self.ITEMS:
                    item = self.ITEMS[item_key]
                    items.append(f"{item[0]} ({item[1]})")
        
        if items:
            self.gui_print("Your items:")
            for item in items:
                self.gui_print(f"  - {item}")
        else:
            self.gui_print("Your inventory is empty!")
        
        # Show equipped items
        self.gui_print("\n⚔️ EQUIPPED:")
        for slot, item_key in player.equipped.items():
            if item_key and item_key in self.ITEMS:
                item = self.ITEMS[item_key]
                self.gui_print(f"  {slot}: {item[0]}")
            else:
                self.gui_print(f"  {slot}: Empty")
        
        self.show_inline_buttons("Inventory", [
            ("⚔️ Equip Item", "1"),
            ("📋 Use Potion", "2"),
            ("⬅️ Back", "back")
        ], lambda c: self.handle_inventory_choice(c))
    
    def handle_inventory_choice(self, c):
        """Handle inventory menu choices."""
        if c == "back":
            self.game_loop()
        elif c == "1":  # Equip
            self._show_equip_menu()
        elif c == "2":  # Use potion
            self._show_use_potion_menu()
    
    def _show_equip_menu(self):
        """Show items that can be equipped."""
        player = self.game.player
        
        # Get equippable items
        equippable = [item for item in player.inventory if item in self.ITEMS and self.ITEMS[item][1] in ["weapon", "armor", "accessory"]]
        
        if not equippable:
            self.gui_print("No equippable items!")
            self.root.after(100, lambda: self.inventory_menu())
            return
        
        self.gui_print("\nSelect item to equip:")
        choices = []
        for item_key in equippable:
            item = self.ITEMS[item_key]
            choices.append((f"{item[0]} ({item[1]})", item_key))
        choices.append(("⬅️ Back", "back"))
        
        self.show_inline_buttons("Equip", choices, lambda item: self._equip_item(item))
    
    def _equip_item(self, item_key):
        """Equip an item."""
        if item_key == "back" or item_key is None:
            self.inventory_menu()
            return
        
        if item_key not in self.ITEMS:
            return
        
        item = self.ITEMS[item_key]
        item_type = item[1]
        
        # Find the right slot
        if item_type == "weapon":
            slot = "weapon"
        elif item_type == "armor":
            slot = "armor"
        elif item_type == "accessory":
            slot = "accessory1" if not self.game.player.equipped["accessory1"] else "accessory2"
        else:
            self.gui_print("Cannot equip this item!")
            self._show_equip_menu()
            return
        
        # Unequip old item if any
        old_item = self.game.player.equipped[slot]
        if old_item:
            self.game.player.inventory.append(old_item)
        
        # Equip new item
        self.game.player.equipped[slot] = item_key
        self.game.player.inventory.remove(item_key)
        
        self.gui_print(f"✅ Equipped: {item[0]}")
        self.root.after(100, lambda: self.inventory_menu())
    
    def _show_use_potion_menu(self):
        """Show potions that can be used."""
        player = self.game.player
        
        # Get potions
        potions = [item for item in player.inventory if item in self.ITEMS and self.ITEMS[item][1] == "potion"]
        
        if not potions:
            self.gui_print("No potions in inventory!")
            self.root.after(100, lambda: self.inventory_menu())
            return
        
        self.gui_print("\nSelect potion to use:")
        choices = []
        for item_key in potions:
            item = self.ITEMS[item_key]
            choices.append((f"{item[0]}", item_key))
        choices.append(("⬅️ Back", "back"))
        
        self.show_inline_buttons("Use Potion", choices, lambda item: self._use_potion(item))
    
    def _use_potion(self, item_key):
        """Use a potion."""
        if item_key == "back" or item_key is None:
            self.inventory_menu()
            return
        
        if item_key not in self.ITEMS:
            return
        
        item = self.ITEMS[item_key]
        player = self.game.player
        
        if "health" in item_key.lower():
            heal = 30
            player.health = min(player.health + heal, player.maxHP)
            self.gui_print(f"💚 Used {item[0]}! Healed {heal} HP.")
        elif "mana" in item_key.lower():
            restore = 20
            player.mp = min(player.mp + restore, player.maxMP)
            self.gui_print(f"💎 Used {item[0]}! Restored {restore} MP.")
        elif "antidote" in item_key.lower():
            self.gui_print(f"🧪 Used {item[0]}! Poison cured.")
        
        # Remove used potion
        player.inventory.remove(item_key)
        self.root.after(100, lambda: self.inventory_menu())
    
    

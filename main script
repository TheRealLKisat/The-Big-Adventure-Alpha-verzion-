                ("⬅️ Back", "back")
            ], lambda c: self._handle_story_quest(c))
        elif sub == "3":  # Achievements
            self.gui_print("🏆 Achievements:")
            self.gui_print("  - Reach Level 5")
            self.gui_print("  - Collect 10 items")
            self.gui_print("  - Defeat the Dragon")
            self.gui_print("  - Join all guilds")
